# ── Trader Application — environment configuration ───────────────────────────
# Copy to ".env" and adjust. NEVER commit a real .env. All values are read by
# backend/app/core/config.py. Missing required config => trading is BLOCKED.

# ── App ──────────────────────────────────────────────────────────────────────
APP_ENV=dev                      # dev | prod
APP_HOST=127.0.0.1
APP_PORT=8000
LOG_LEVEL=INFO                   # DEBUG | INFO | WARNING | ERROR
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
API_AUTH_REQUIRED=false           # production/real trading must set true
API_AUTH_TOKEN=                   # long random bearer token; never commit the real value
API_OPERATOR_NAME=operator        # trusted actor written to audit logs
USER_AUTH_ENABLED=false           # true = browser login uses each user's MT5 login number
AUTH_BOOTSTRAP_ENABLED=true        # allow creation of the first owner only
AUTH_COOKIE_NAME=thangrod_session
AUTH_CSRF_COOKIE_NAME=thangrod_csrf
AUTH_SESSION_HOURS=12
AUTH_MAX_FAILED_ATTEMPTS=5
AUTH_LOCK_MINUTES=15

# Browser login uses MT5 login as the username, but AUTH NEVER accepts or stores
# the broker/MT5 password. Each user creates a separate application password.

# ── Database ─────────────────────────────────────────────────────────────────
# Leave blank in dev to use a local SQLite file (./trader_dev.db).
# Local PostgreSQL example:
DATABASE_URL=postgresql+psycopg://postgres:postgres@127.0.0.1:5432/trader

# Docker Compose PostgreSQL (use URL-safe random values)
POSTGRES_DB=trader
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
WEB_PORT=8080
COMPOSE_EMERGENCY_STOP=true      # Docker safety override; keep true for initial deployment

# ── Trading mode ─────────────────────────────────────────────────────────────
# MANUAL_ONLY | AUTO_DEMO | AUTO_REAL_APPROVAL_REQUIRED | AUTO_REAL_FULL
TRADING_MODE=MANUAL_ONLY

# ── Safety flags (auto-real needs ALL three conditions) ──────────────────────
# Real trades are impossible unless ALLOW_REAL_TRADING=true.
# Fully-automatic real trades need ALLOW_REAL_TRADING=true AND ALLOW_AUTO_REAL_FULL=true
# AND EMERGENCY_STOP=false. Defaults below keep real auto trading OFF.
ALLOW_REAL_TRADING=false
ALLOW_AUTO_REAL_FULL=false
EMERGENCY_STOP=false             # kill switch: true => block ALL order placement

# ── MT5 bridge ───────────────────────────────────────────────────────────────
MT5_BRIDGE_TYPE=mock             # mock | ea_socket   (Phase 1: keep "mock")
MT5_EA_HOST=127.0.0.1             # backend listen address; EA connects outward
MT5_EA_PORT=5555                  # backend listen port
MT5_EA_SHARED_SECRET=             # required for ea_socket; same value as the EA input
MT5_EA_ALLOW_REMOTE_BIND=false    # enable only over a protected network
MT5_BRIDGE_TIMEOUT_SEC=5
MT5_HEARTBEAT_MAX_AGE_SEC=15     # bridge considered unhealthy if last heartbeat older than this
MT5_EXPECTED_LOGIN=               # required for ea_socket; password stays inside MT5 Terminal
MT5_EXPECTED_SERVER=              # exact broker server name, e.g. Broker-Demo
MT5_EXPECTED_ACCOUNT_TYPE=UNKNOWN # DEMO | REAL | UNKNOWN (ea_socket must use DEMO/REAL)
# Mock-only knobs (ignored by ea_socket): healthy | unhealthy ; demo | real | unknown
MOCK_BRIDGE_HEALTH=healthy
MOCK_ACCOUNT_TYPE=demo

# Bridge resilience (ea_socket reads only; execute_order is never retried)
BRIDGE_RETRY_MAX_ATTEMPTS=2         # total attempts per idempotent read (1 = no retry)
BRIDGE_RETRY_BACKOFF_BASE_SEC=0.2   # exponential backoff base, jittered 50–100%
BRIDGE_RETRY_BACKOFF_MAX_SEC=2       # backoff ceiling per retry
BRIDGE_CIRCUIT_FAIL_THRESHOLD=5     # consecutive failures before the circuit opens
BRIDGE_CIRCUIT_RESET_SEC=30         # cooldown before a half-open trial call

# ── Risk configuration (no hardcoded risk anywhere in code) ──────────────────
RISK_MAX_RISK_PER_TRADE_PCT=1.0
RISK_MAX_PORTFOLIO_RISK_PCT=5.0
RISK_DAILY_MAX_LOSS_PCT=3.0
RISK_MAX_TRADES_PER_DAY=5
RISK_MAX_OPEN_POSITIONS=3
RISK_MAX_SPREAD_POINTS=50
RISK_COOLDOWN_MINUTES_AFTER_LOSS=30
RISK_NEWS_BLOCK_WINDOW_MIN=30    # block trading within N minutes of a high-impact event
RISK_MIN_FREE_MARGIN_PCT=50.0    # block if free margin below this % of equity
RISK_MAX_ORDER_VOLUME_LOTS=1.0   # hard safety ceiling; position sizing may choose less

# ── Interval workflow ────────────────────────────────────────────────────────
STRATEGY_TIMEFRAME=H1              # candle timeframe for D40/D20 Donchian: M1/M5/M15/M30/H1/H4/D1
WORKFLOW_INTERVAL_SECONDS=300
WORKFLOW_MAX_BACKOFF_SECONDS=3600  # cap when backing off after consecutive failures
APPROVAL_EXPIRY_MINUTES=30
RECONCILIATION_EXPIRY_MINUTES=15
RECONCILIATION_BATCH_SIZE=20

# ── XAUUSD strategy / proposals ──────────────────────────────────────────────
# The exact D40/D20 signal definition is not yet confirmed. Enabling this only
# permits manual proposal generation; it does not turn on automatic signals.
STRATEGY_XAUUSD_ENABLED=false
STRATEGY_D40_VALUE=40
STRATEGY_D20_VALUE=20
STRATEGY_REWARD_RISK_RATIO=2
STRATEGY_RISK_PCT=1
STRATEGY_SIGNAL_DEFINITION_CONFIRMED=false
PROPOSAL_EXPIRY_MINUTES=15

# ── Legacy cloud AI placeholders (adapters not implemented) ─────────────────
AI_PRIMARY_PROVIDER=claude       # claude | openai | local
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
LOCAL_LLM_URL=

# Analysis provider registry / MCP client
# Only exact hosts listed here can be contacted by configured MCP providers.
# Add remote hosts deliberately; non-local endpoints must use HTTPS.
MCP_ALLOWED_HOSTS=localhost,127.0.0.1,::1
MCP_MAX_DISCOVERED_TOOLS=100
# Local/Open WebUI endpoints use a separate exact host allowlist. A remote
# endpoint must use HTTPS. The UI stores only ANALYSIS_PROVIDER_* references.
ANALYSIS_PROVIDER_ALLOWED_HOSTS=localhost,127.0.0.1,::1
OPENAI_PROVIDER_ALLOWED_HOSTS=api.openai.com
ANALYSIS_PROVIDER_MAX_RESPONSE_CHARS=12000
ANALYSIS_PROVIDER_HEALTH_CHECKS_ENABLED=true
ANALYSIS_PROVIDER_HEALTH_CHECK_INTERVAL_SECONDS=300
ANALYSIS_PROVIDER_HEALTH_CHECK_BATCH_SIZE=10
WORKFLOW_ANALYSIS_ENABLED=false  # advisory chart summary in each workflow cycle
# Provider tokens are environment-managed. The UI stores only a reference such
# as MCP_PROVIDER_NEWS_TOKEN, never the value itself.
# MCP_PROVIDER_NEWS_TOKEN=
# ANALYSIS_PROVIDER_OPEN_WEBUI_KEY=
# ANALYSIS_PROVIDER_OPENAI_KEY=

# ── News provider (Phase 2) ──────────────────────────────────────────────────
NEWS_PROVIDER=mock               # mock | <future real provider>
NEWS_API_KEY=
VOLATILITY_PROVIDER=mock         # mock | <future live provider>

# Read-only realtime watchlist. Execution/risk prices still come from MT5.
MARKET_DATA_ENABLED=true
MARKET_DATA_PROVIDER=mt5         # mt5 | alpaca | disabled
MARKET_DATA_ENDPOINT=wss://stream.data.alpaca.markets/v2
MARKET_DATA_FEED=iex             # iex | sip | delayed_sip
MARKET_DATA_API_KEY_REF=MARKET_DATA_ALPACA_KEY
MARKET_DATA_API_SECRET_REF=MARKET_DATA_ALPACA_SECRET
MARKET_DATA_DEFAULT_SYMBOLS=XAUUSD
MARKET_DATA_MAX_SYMBOLS=25
MARKET_DATA_TIMEOUT_SEC=10
MARKET_DATA_ALLOWED_HOSTS=stream.data.alpaca.markets
# MARKET_DATA_ALPACA_KEY=
# MARKET_DATA_ALPACA_SECRET=
